{
    "name": "mindtwo/laravel-monitoring",
    "description": "Laravel plugin of the mindtwo monitoring suite: framework-specific collectors, a scheduled push job and a signed pull endpoint on top of mindtwo/base-monitoring.",
    "keywords": [
        "mindtwo",
        "laravel",
        "monitoring",
        "infrastructure",
        "security"
    ],
    "homepage": "https://github.com/mindtwo/laravel-monitoring",
    "license": "MIT",
    "authors": [
        {
            "name": "mindtwo GmbH",
            "email": "info@mindtwo.de",
            "homepage": "https://www.mindtwo.de",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "composer-runtime-api": "^2.0",
        "guzzlehttp/guzzle": "^7.4",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "mindtwo/base-monitoring": "^1.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.9|^3.0",
        "laravel/pint": "^1.13",
        "orchestra/testbench": "^8.22|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.34|^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^2.3|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Mindtwo\\Monitoring\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mindtwo\\Monitoring\\Laravel\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "lint": "vendor/bin/pint --test",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "check": [
            "@lint",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        },
        "laravel": {
            "providers": [
                "Mindtwo\\Monitoring\\Laravel\\MonitoringServiceProvider"
            ],
            "aliases": {
                "Monitoring": "Mindtwo\\Monitoring\\Laravel\\Facades\\Monitoring"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
